# -------------------------------------------------------------------
# Home Finance Tracker — MCP server config
# Copy to ".env" (or set these in your Claude MCP config "env" block).
# -------------------------------------------------------------------

# Supabase project URL (same as the app).
SUPABASE_URL=

# SERVICE ROLE key — Project Settings -> API -> service_role.
# KEEP SECRET. It bypasses Row Level Security, so this server scopes
# every query to the single household below.
SUPABASE_SERVICE_ROLE_KEY=

# The household this Claude connection may read/write.
# Get it from Supabase: Table editor -> households -> copy the id.
HOUSEHOLD_ID=

# Optional: the profile id used as "created_by"/"paid_by" default when
# Claude adds an expense (Table editor -> profiles -> copy an id).
DEFAULT_PROFILE_ID=
    