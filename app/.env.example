# ---------------------------------------------------------------
# Copy this file to ".env" and fill in the values, then restart.
# Get these from: Supabase Dashboard -> Project Settings -> API
# ---------------------------------------------------------------

# Your project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# The "anon / public" key (safe to expose in a frontend).
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------
# NOTE: If you leave these blank, the app still runs in LOCAL MODE
# (data saved only on this device) so you can try it immediately.
# Fill them in to switch to shared, multi-device cloud mode.
# ---------------------------------------------------------------
